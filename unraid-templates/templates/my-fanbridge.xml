<?xml version="1.0" encoding="utf-8"?>
<Application>
  <Name>FanBridge</Name>
  <Overview><![CDATA[
  FanBridge is a lightweight Docker container that acts as a bridge between your Unraid server and an external RP2040 microcontroller. It intelligently reads your Unraid drive temperatures (HDD/SSD) and transmits them over USB serial, allowing the microcontroller to perfectly orchestrate your PWM fans.
  
  Features include a beautiful dark-mode web UI, real-time temperature graphing, custom PWM curves, and seamless OTA firmware updates for your RP2040 controller directly from the dashboard.]]></Overview>
  <Category>Utilities: System:Tools</Category>
  <Registry>https://github.com/RoBroLabs/fanbridge/pkgs/container/fanbridge</Registry>
  <Repository>ghcr.io/robrolabs/fanbridge:latest</Repository>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Icon>https://raw.githubusercontent.com/RoBroLabs/fanbridge/main/container/static/fanbridge.png</Icon>
  <Project>https://github.com/RoBroLabs/fanbridge</Project>
  <ReadMe>https://github.com/RoBroLabs/fanbridge#readme</ReadMe>
  <Support>https://forums.unraid.net/topic/193488-fanbridge-docker-support/</Support>
  <DonateText>Support FanBridge Development</DonateText>
  <DonateLink>https://ko-fi.com/robrolabs</DonateLink>
  <ExtraParams>
    --label net.unraid.docker.managed=dockerman
    --label net.unraid.docker.webui='http://[IP]:[PORT:8080]/'
    --label net.unraid.docker.icon='https://raw.githubusercontent.com/RoBroLabs/fanbridge/main/container/static/fanbridge.png'
  </ExtraParams>

  <!-- Ports -->
  <Config Name="Web UI Port" Target="8080" Default="8080" Mode="tcp" Type="Port" Description="Web interface port" Display="always" Required="true" Mask="false">8080</Config>

  <!-- Paths (Host → Container) -->
  <Config Name="AppData (config)" Target="/config" Default="/mnt/maincache/appdata/fanbridge" Type="Path" Mode="rw" Description="Container configuration directory. Persist settings and user data here." Display="always" Required="true" Mask="false"/>

  <Config Name="Unraid emhttp directory (read-only)" Target="/unraid" Default="/var/local/emhttp" Type="Path" Mode="ro" Description="Bind the full emhttp directory (preferred)." Display="always" Required="false" Mask="false"/>

  <!-- Serial TTY: default /dev/ttyACM0 -->
  <Config Name="Serial TTY" Target="/dev/ttyACM0" Default="/dev/ttyACM0" Type="Path" Mode="rw" Description="Bind the serial device inside the container at the same path." Display="always" Required="false" Mask="false"/>
  <Config Name="/dev/ttyACM0" Target="/dev/ttyACM0" Default="/dev/ttyACM0" Type="Device" Description="Expose the serial device directly." Display="always" Required="false" Mask="false"/>

  <!-- Optional: single-file bind (advanced) -->
  <Config Name="Unraid disks.ini (ro)" Target="/unraid/disks.ini" Default="/var/local/emhttp/disks.ini" Type="Path" Mode="ro" Description="Bind only disks.ini (optional)." Display="advanced" Required="false" Mask="false"/>

  <!-- Firmware update support (optional, advanced) -->
  <Config Name="USB Bus (for FW updates)" Target="/dev/bus/usb" Default="/dev/bus/usb" Type="Path" Mode="rw" Description="Required for RP2040 firmware updates. The controller changes USB identity during BOOTSEL; this mapping lets the container detect it." Display="advanced" Required="false" Mask="false"/>
  <Config Name="Disk by-label (for FW updates)" Target="/dev/disk/by-label" Default="/dev/disk/by-label" Type="Path" Mode="ro" Description="Helps the container locate the RPI-RP2 boot volume by label during firmware updates." Display="advanced" Required="false" Mask="false"/>

  <Version>1.2.3</Version>
</Application>
