# Local development only
# - Uses a local config file so you don't touch /config (created on first run)
# - Forces UI version to "local"
# - Enables template auto-reload for quick HTML/CSS tweaks
FANBRIDGE_CONFIG=./config.local.yml
FANBRIDGE_FORCE_LOCAL_VERSION=1
FLASK_DEBUG=1
TEMPLATES_AUTO_RELOAD=1
# The standalone Flask development server is deliberately loopback-only.
# Use the container/Gunicorn deployment for access from another machine.
FANBRIDGE_DEV_HOST=127.0.0.1

# Point this at a real, read-only disks.ini fixture when testing the control
# path. Synthetic drive data is disabled unless explicitly opted in.
# FANBRIDGE_DISKS_INI=/absolute/path/to/disks.ini
# FANBRIDGE_ALLOW_SIMULATION=1
